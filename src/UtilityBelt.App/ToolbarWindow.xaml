<Window x:Class="UtilityBelt.App.ToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:UtilityBelt.App.Models"
        xmlns:services="clr-namespace:UtilityBelt.App.Services"
        Title="UtilityBelt"
        Height="240"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        Foreground="White"
        AllowsTransparency="True"
        Deactivated="Window_Deactivated"
        PreviewMouseDown="Window_PreviewMouseDown"
        MouseLeave="Window_MouseLeave"
        MouseEnter="Window_MouseEnter">

    <Window.InputBindings>
        <!-- Left-click on the window background toggles pinning (suppresses auto-hide while pinned). -->
        <MouseBinding MouseAction="LeftClick" Command="{Binding TogglePinnedCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <SolidColorBrush x:Key="DefaultButtonBack" Color="#FF2B2B2B" />
        <SolidColorBrush x:Key="DefaultButtonFore" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="DefaultButtonBorder" Color="#FF3A3A3A" />

        <CornerRadius x:Key="ButtonCornerRadius">12</CornerRadius>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="3" />
            <Setter Property="MinHeight" Value="{Binding CurrentUiSettings.ButtonMinHeight, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Setter Property="MinWidth" Value="{Binding CurrentUiSettings.ButtonMinWidth, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Setter Property="Padding" Value="{Binding CurrentUiSettings, RelativeSource={RelativeSource AncestorType=Window}, Converter={x:Static services:UiSettingsToThicknessConverter.ButtonPadding}}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource DefaultButtonBack}" />
            <Setter Property="Foreground" Value="{StaticResource DefaultButtonFore}" />
            <Setter Property="BorderBrush" Value="{StaticResource DefaultButtonBorder}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource ButtonCornerRadius}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="Card"
            CornerRadius="10"
            BorderThickness="1"
            BorderBrush="#333"
            Background="#FF1E1E1E"
            Padding="12">
        <Border.InputBindings>
            <MouseBinding MouseAction="LeftClick" Command="{Binding BeginDragCommand}" />
        </Border.InputBindings>

        <DockPanel>
            <TextBlock DockPanel.Dock="Top" FontSize="14" FontWeight="SemiBold" Text="UtilityBelt" Margin="0,0,0,10" />

            <ItemsControl ItemsSource="{Binding Buttons}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding DataContext.Columns, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ButtonDefinition}">
                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                ToolTip="{Binding Tooltip}"
                                Background="{Binding BackColor, Converter={x:Static services:ButtonBrushConverter.Background}}"
                                Foreground="{Binding ForegroundColor, Converter={x:Static services:ButtonBrushConverter.Foreground}}"
                                BorderBrush="{Binding BackColor, Converter={x:Static services:ButtonBrushConverter.Border}}"
                                Command="{Binding DataContext.RunButtonCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}">

                            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Icon: shown only when PathData exists -->
                                <Path x:Name="Icon"
                                      Grid.Row="0"
                                      Data="{Binding PathData, Converter={x:Static services:PathDataToGeometryConverter.Instance}}"
                                      Fill="{Binding ForegroundColor, Converter={x:Static services:ButtonBrushConverter.Foreground}}"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Width="{Binding CurrentUiSettings.ButtonIconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Height="{Binding CurrentUiSettings.ButtonIconSize, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PathData}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PathData}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>

                                                <!-- Icon-only (no label): grow icon -->
                                                <DataTrigger Binding="{Binding Label}" Value="">
                                                    <Setter Property="Width" Value="{Binding CurrentUiSettings.ButtonIconOnlySize, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                    <Setter Property="Height" Value="{Binding CurrentUiSettings.ButtonIconOnlySize, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                    <Setter Property="Grid.RowSpan" Value="2" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>

                                <!-- Text: 2-line max when icon exists; bigger + centered when no icon -->
                                <TextBlock x:Name="Label"
                                           Grid.Row="1"
                                           Text="{Binding Label}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           FontSize="{Binding CurrentUiSettings.ButtonTextWithIconFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                           MaxHeight="32">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <!-- Icon-only: hide label -->
                                                <DataTrigger Binding="{Binding Label}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>

                                                <!-- No icon: make label larger and center it vertically -->
                                                <DataTrigger Binding="{Binding PathData}" Value="">
                                                    <Setter Property="TextElement.FontSize" Value="{Binding CurrentUiSettings.ButtonTextFontSize, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                    <Setter Property="Margin" Value="0" />
                                                    <Setter Property="Grid.Row" Value="0" />
                                                    <Setter Property="Grid.RowSpan" Value="2" />
                                                    <Setter Property="MaxHeight" Value="60" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PathData}" Value="{x:Null}">
                                                    <Setter Property="TextElement.FontSize" Value="{Binding CurrentUiSettings.ButtonTextFontSize, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                    <Setter Property="Margin" Value="0" />
                                                    <Setter Property="Grid.Row" Value="0" />
                                                    <Setter Property="Grid.RowSpan" Value="2" />
                                                    <Setter Property="MaxHeight" Value="60" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                            </Grid>

                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock DockPanel.Dock="Bottom"
                       Margin="0,8,0,0"
                       Opacity="0.55"
                       FontSize="10"
                       TextWrapping="Wrap"
                       Text="Buttons are configured via %AppData%\UtilityBelt\appsettings.json" />
        </DockPanel>
    </Border>
</Window>
